    },
    {
      "@type": "HowTo",
      "@id": "https://tidos.dev/docs/getting-started#howto",
      "name": "How to add Tidos to your Rust project",
      "description": "Add the Tidos component framework to a Rust web app and render your first page.",
      "inLanguage": "en",
      "about": { "@id": "https://tidos.dev/#tidos" },
      "step": [
        {
          "@type": "HowToStep",
          "position": "1",
          "name": "Choose your web framework",
          "text": "Select your preferred Rust web framework: Rocket, Actix, Axum, Warp, or use Tidos standalone without a framework."
        },
        {
          "@type": "HowToStep",
          "position": "2",
          "name": "Add Tidos to Cargo.toml",
          "text": "Add tidos as a dependency with the feature flag matching your framework, e.g. tidos = { version = \"0.7.2\", features = [\"rocket\"] }."
        },
        {
          "@type": "HowToStep",
          "position": "3",
          "name": "Create a route handler with page!",
          "text": "Use the page! macro inside a route handler function to produce a Page struct. Return the Page from the handler — your framework serves it directly as an HTML response."
        },
        {
          "@type": "HowToStep",
          "position": "4",
          "name": "Run your server",
          "text": "Start your web server with cargo run and open the rendered page in your browser."
        }
      ]
    },
    {
