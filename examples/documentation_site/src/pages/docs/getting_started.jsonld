      "name": "Getting Started — Tidos",
      "description": "How to add Tidos to your Rust project with Rocket, Actix, Axum, Warp, or standalone.",
      "url": "https://tidos.dev/docs/getting-started",
      "isPartOf": { "@id": "https://tidos.dev/#website" },
      "author": { "@id": "https://github.com/kaasbroodju" },
