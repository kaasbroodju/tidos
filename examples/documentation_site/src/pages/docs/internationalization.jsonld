{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TechArticle",
      "@id": "https://tidos.dev/docs/internationalization#article",
      "name": "Internationalization — Tidos",
      "description": "How to add i18n support to a Tidos app using Fluent (.ftl) files and the i18n! macro.",
      "url": "https://tidos.dev/docs/internationalization",
      "isPartOf": { "@id": "https://tidos.dev/#website" },
      "author": { "@id": "https://github.com/kaasbroodju" },
      "inLanguage": "en",
      "about": { "@id": "https://tidos.dev/#tidos" }
    },
    {
      "@type": "HowTo",
      "@id": "https://tidos.dev/docs/internationalization#howto",
      "name": "How to add internationalization to a Tidos app",
      "description": "Enable locale-aware translations, pluralization, and gender variants in a Tidos app using the Fluent i18n feature.",
      "inLanguage": "en",
      "about": { "@id": "https://tidos.dev/#tidos" },
      "step": [
        {
          "@type": "HowToStep",
          "position": "1",
          "name": "Enable the i18n feature flag",
          "text": "Add the i18n feature to your tidos dependency in Cargo.toml: tidos = { version = \"0.7.2\", features = [\"rocket\", \"i18n\"] }."
        },
        {
          "@type": "HowToStep",
          "position": "2",
          "name": "Create Tidos.toml",
          "text": "Add a Tidos.toml file in the project root. Configure resource_location (the translations folder), default_locale, and the list of .ftl resource files."
        },
        {
          "@type": "HowToStep",
          "position": "3",
          "name": "Add Fluent translation files",
          "text": "Create .ftl files under the translations directory, organised by locale (e.g. translations/en-US/common.ftl). Write Fluent messages with optional variables, plurals, and gender selectors."
        },
        {
          "@type": "HowToStep",
          "position": "4",
          "name": "Initialize with enable_i18n!()",
          "text": "Call enable_i18n!() once at the top level of main.rs to load the translation configuration before the server starts."
        },
        {
          "@type": "HowToStep",
          "position": "5",
          "name": "Add lang: Lang to route handlers",
          "text": "Add a lang: Lang parameter to each route handler. The locale is read from the first URL path segment (e.g. /en-US or /nl-NL) and picked up automatically by page!."
        },
        {
          "@type": "HowToStep",
          "position": "6",
          "name": "Translate strings with i18n!",
          "text": "Inside any component call i18n!(\"message-key\") for simple lookups, or i18n!(\"message-key\", (\"var\", value), ...) to pass Fluent variables for pluralization and interpolation."
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tidos.dev" },
        { "@type": "ListItem", "position": 2, "name": "Internationalization", "item": "https://tidos.dev/docs/internationalization" }
      ]
    }
  ]
}
