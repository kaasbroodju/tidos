{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TechArticle",
      "@id": "https://tidos.dev/docs/component#article",
      "name": "Component — Tidos",
      "description": "How to build reusable components in Tidos using the Component trait, view! macro, control tags, slots, head!, and scoped_css!.",
      "url": "https://tidos.dev/docs/component",
      "isPartOf": { "@id": "https://tidos.dev/#website" },
      "author": { "@id": "https://github.com/kaasbroodju" },
      "inLanguage": "en",
      "about": { "@id": "https://tidos.dev/#tidos" }
    },
    {
      "@type": "HowTo",
      "@id": "https://tidos.dev/docs/component#howto",
      "name": "How to build a reusable Tidos component",
      "description": "Create a typed, reusable UI component in Tidos using the Component trait and the view! macro.",
      "inLanguage": "en",
      "about": { "@id": "https://tidos.dev/#tidos" },
      "step": [
        {
          "@type": "HowToStep",
          "position": "1",
          "name": "Create a Rust struct",
          "text": "Define a plain Rust struct with pub fields for each prop your component accepts."
        },
        {
          "@type": "HowToStep",
          "position": "2",
          "name": "Implement the Component trait",
          "text": "Implement Component for your struct. The to_render method receives a mutable Page reference and calls view! to produce HTML output."
        },
        {
          "@type": "HowToStep",
          "position": "3",
          "name": "Write HTML with view!",
          "text": "Inside to_render call the view! macro. All text between tags must be wrapped in {}. Use {\"literal\"}, {expr}, or @html{expr} depending on whether the content is static, an expression, or raw HTML."
        },
        {
          "@type": "HowToStep",
          "position": "4",
          "name": "Add control flow with control tags",
          "text": "Use {#if}…{/if}, {#for}…{/for}, and {#match}…{/match} blocks inside view! for conditionals, loops, and pattern matching."
        },
        {
          "@type": "HowToStep",
          "position": "5",
          "name": "Pass HTML into child components with slots",
          "text": "Use {#slot:name}…{/slot} in the parent to pass rendered HTML as a prop. In the child component declare a Slot field and render it with @slot{self.name}."
        },
        {
          "@type": "HowToStep",
          "position": "6",
          "name": "Inject head elements with head!",
          "text": "Call head! inside to_render to add stylesheets, scripts, or meta tags to the page head. Injections are deduplicated automatically."
        },
        {
          "@type": "HowToStep",
          "position": "7",
          "name": "Apply scoped styles with scoped_css!",
          "text": "Call scoped_css!(\"./component.css\") on the root element's class attribute to inject a scoped style block and receive the generated class name."
        }
      ]
    },
